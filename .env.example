# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lake_evendim"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth.js
AUTH_SECRET="your-auth-secret-here-run-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Azure AD) SSO
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-client-secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"

# Credential Encryption (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters. If unset, credentials stored as plain JSON (dev only).
ENCRYPTION_KEY=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Lake Evendim"
